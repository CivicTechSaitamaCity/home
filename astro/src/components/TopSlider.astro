---
import { getNewsEntries } from "../lib/content";
import type { ContentEntry } from "../lib/content";

const items: ContentEntry[] = getNewsEntries(10);
---

<section class="hero-slider" aria-label="最近のイベント">
  <div class="hero-slider__controls">
    <button
      class="hero-slider__pause"
      id="slider-pause"
      type="button"
      aria-label="スライダーを一時停止"
      aria-pressed="false"
    >
      <span class="hero-slider__pause-icon" aria-hidden="true">⏸</span>
    </button>
  </div>
  <div class="hero-slider__viewport" data-slider-viewport>
    <div class="hero-slider__track">
      {
        items.map((item, index) => (
          <div
            class="hero-slider__slide"
            aria-hidden={index >= items.length ? "true" : undefined}
          >
            <a
              href={item.frontmatter.link}
              target="_blank"
              rel="noreferrer"
              aria-label={`${item.frontmatter.title}（新しいタブで開く）`}
            >
              <img
                src={item.frontmatter.thumb}
                alt={item.frontmatter.title}
                loading={index < 2 ? "eager" : "lazy"}
              />
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  const viewport = document.querySelector("[data-slider-viewport]");
  const pauseBtn = document.getElementById("slider-pause");
  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (viewport instanceof HTMLElement) {
    const advance = () => {
      const slide = viewport.querySelector(".hero-slider__slide");
      const track = viewport.querySelector(".hero-slider__track");
      const gap =
        track instanceof HTMLElement
          ? Number.parseFloat(window.getComputedStyle(track).gap || "0")
          : 0;
      const amount =
        slide instanceof HTMLElement
          ? slide.clientWidth + (Number.isFinite(gap) ? gap : 0)
          : viewport.clientWidth;
      const remaining =
        viewport.scrollWidth - viewport.clientWidth - viewport.scrollLeft;

      if (remaining <= amount) {
        viewport.scrollTo({ left: 0, behavior: "smooth" });
        return;
      }

      viewport.scrollBy({ left: amount, behavior: "smooth" });
    };

    let intervalId = null;

    const start = () => {
      if (intervalId === null) {
        intervalId = window.setInterval(advance, 6000);
      }
    };

    const stop = () => {
      if (intervalId !== null) {
        window.clearInterval(intervalId);
        intervalId = null;
      }
    };

    // Don't auto-play if user prefers reduced motion
    if (!prefersReduced) {
      start();
    }

    if (pauseBtn) {
      pauseBtn.addEventListener("click", () => {
        const isPaused = pauseBtn.getAttribute("aria-pressed") === "true";
        if (isPaused) {
          start();
          pauseBtn.setAttribute("aria-pressed", "false");
          pauseBtn.setAttribute("aria-label", "スライダーを一時停止");
          pauseBtn.querySelector(".hero-slider__pause-icon").textContent = "⏸";
        } else {
          stop();
          pauseBtn.setAttribute("aria-pressed", "true");
          pauseBtn.setAttribute("aria-label", "スライダーを再生");
          pauseBtn.querySelector(".hero-slider__pause-icon").textContent = "▶";
        }
      });

      // Show button as already paused if reduced motion
      if (prefersReduced) {
        pauseBtn.setAttribute("aria-pressed", "true");
        pauseBtn.setAttribute("aria-label", "スライダーを再生");
        pauseBtn.querySelector(".hero-slider__pause-icon").textContent = "▶";
      }
    }
  }
</script>
