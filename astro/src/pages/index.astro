---
import TopSlider from "../components/TopSlider.astro";
import MarkdownSection from "../components/MarkdownSection.astro";
import NewsList from "../components/NewsList.astro";
import EventGrid from "../components/EventGrid.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEventEntries, getNewsEntries, getPageEntry } from "../lib/content";

const news = getNewsEntries(8);
const events = getEventEntries(8);
const projects = getPageEntry("projects");
const message = getPageEntry("message");
const vision = getPageEntry("vision");

if (!projects || !message || !vision) {
  throw new Error("Expected top page content was not found.");
}
---

<BaseLayout>
  <h1 class="sr-only">シビックテックさいたま</h1>
  <TopSlider />

  <article>
    <div class="content-block">
      <h2 id="news">News</h2>
      <NewsList items={news} compact />
      <a class="section-more" href="/news" aria-label="ニュース一覧をもっと見る"
        >more...</a
      >
    </div>
  </article>

  <MarkdownSection id="project" entry={projects} />

  <article>
    <div class="content-block">
      <h2 id="event">Event</h2>
      <EventGrid items={events} />
      <a
        class="section-more"
        href="/events"
        aria-label="イベント一覧をもっと見る">more...</a
      >
    </div>
  </article>

  <MarkdownSection id="message" entry={message} />
  <MarkdownSection id="vision" entry={vision} />

  <article>
    <div class="content-block">
      <h2>Contact</h2>
      <ul class="contact-list">
        <li>
          シビックテックさいたま世話人：太田一穂、クワハラシズカ、藤田史織、古川尚史、冨田かおり
        </li>
        <li>
          email：<a href="mailto:civictech.saitama@gmail.com"
            >civictech.saitama@gmail.com</a
          >
        </li>
        <li>
          <a
            href="https://www.facebook.com/CivicTechSaitamaCity"
            target="_blank"
            rel="noreferrer"
            aria-label="Facebook（新しいタブで開く）"
          >
            <img src="/images/iconFb.png" alt="Facebook" />
          </a>
        </li>
      </ul>
    </div>
  </article>
</BaseLayout>
