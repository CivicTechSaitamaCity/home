---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate } from "../lib/formatDate";
import { getDisplayTitle, getReportEntries } from "../lib/content";

const reports = getReportEntries();
---

<BaseLayout
  title="Report | シビックテックさいたま"
  description="シビックテックさいたまのイベントレポート一覧です。"
>
  <h1 class="page-heading">Report</h1>
  <section class="report-list" aria-label="レポート一覧">
    {
      reports.map((article) => (
        <a href={article.path} class="report-link">
          <div class="report-item">
            <div class="report-item__date">
              <time datetime={article.frontmatter.reportDate}>
                {formatDate(article.frontmatter.reportDate)}
              </time>
            </div>
            <div class="report-item__title">{getDisplayTitle(article)}</div>
          </div>
        </a>
      ))
    }
  </section>
</BaseLayout>
