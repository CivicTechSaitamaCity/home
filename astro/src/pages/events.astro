---
import BaseLayout from "../layouts/BaseLayout.astro";
import EventGrid from "../components/EventGrid.astro";
import { getEventEntries } from "../lib/content";

const events = getEventEntries();
---

<BaseLayout title="Event | シビックテックさいたま">
  <article>
    <div class="content-block">
      <h1 id="event" class="page-heading">Event</h1>
      <EventGrid items={events} />
    </div>
  </article>
</BaseLayout>
