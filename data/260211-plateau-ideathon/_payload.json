[{"data":1,"prerenderedAt":156},["ShallowReactive",2],{"content-query-sLngqdmiZM":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":7,"date":9,"eventDate":10,"reportDate":11,"link":12,"thumb":13,"body":14,"_type":150,"_id":151,"_source":152,"_file":153,"_stem":154,"_extension":155},"/data/260211-plateau-ideathon","data",false,"","2月11日に、「国土交通省の3D都市モデル活用プロジェクト『PLATEAU（プラトー）』アイデアソン2025 inさいたま」を開催します！","2026-02-11","2026-01-17","2026-02-17","https://civictechsaitama202602.peatix.com/","/images/report/260211/260211-plateau-ideathon.png",{"type":15,"children":16,"toc":144},"root",[17,26,36,41,46,50,57,62,67,75,81,86,91,99,105,110,118],{"type":18,"tag":19,"props":20,"children":22},"element","h1",{"id":21},"開催レポートplateauアイデアソン-in-さいたま-2025",[23],{"type":24,"value":25},"text","【開催レポート】PLATEAUアイデアソン in さいたま 2025",{"type":18,"tag":27,"props":28,"children":29},"p",{},[30],{"type":18,"tag":31,"props":32,"children":35},"img",{"alt":33,"src":34},"会場の様子（表紙）","/images/report/260211/cover.jpg",[],{"type":18,"tag":27,"props":37,"children":38},{},[39],{"type":24,"value":40},"シビックテックさいたまでは、テクノロジーに苦手意識を持っていたり、普段馴染みがなかったりする人たちでも参加できるように、日ごろから「入門編」「初心者向け」として、勉強会やイベントを開催しています。",{"type":18,"tag":27,"props":42,"children":43},{},[44],{"type":24,"value":45},"2026年2月11日（祝）に、国土交通省が推進する日本全国の都市の3Dモデル化プロジェクトPLATEAU（プラトー）のデータ活用して「さいたま市で何が出来るか？」を考えるために、地域課題に取り組むNPO、学生、エンジニア、デザイナーなどを対象とし、PLATEAUについて学んだり、活用アイデアを考えたりするイベントをさいたま市大宮区「エムズスクエア（武蔵野銀行本店2階）」で開催しました。",{"type":18,"tag":47,"props":48,"children":49},"hr",{},[],{"type":18,"tag":51,"props":52,"children":54},"h2",{"id":53},"知るplateauがもたらす都市のデジタル化",[55],{"type":24,"value":56},"【知る】PLATEAUがもたらす都市のデジタル化",{"type":18,"tag":27,"props":58,"children":59},{},[60],{"type":24,"value":61},"冒頭の講演では、国土交通省の十川さまより、PLATEAUの基礎知識と全国での活用事例をご紹介いただきました 。続いて、株式会社福山コンサルタントの黒木さまより、防災分野での実際のデータを用いた地域事例の紹介が行われました 。",{"type":18,"tag":27,"props":63,"children":64},{},[65],{"type":24,"value":66},"これらを通して、3D都市モデルが単なる地図ではなく、シミュレーションや分析に活用できる「都市のプラットフォーム」であることを学びました。",{"type":18,"tag":27,"props":68,"children":69},{},[70],{"type":18,"tag":31,"props":71,"children":74},{"alt":72,"src":73},"講演の様子","/images/report/260211/know-lecture.jpg",[],{"type":18,"tag":51,"props":76,"children":78},{"id":77},"触るハンズオンデジタル空間のさいたま市を体験",[79],{"type":24,"value":80},"【触る】ハンズオン：デジタル空間のさいたま市を体験",{"type":18,"tag":27,"props":82,"children":83},{},[84],{"type":24,"value":85},"株式会社Eukaryaの萩原さまのガイドにより、Webブラウザ上でPLATEAUデータを操作できる「PLATEAU View」のハンズオンを実施しました 。",{"type":18,"tag":27,"props":87,"children":88},{},[89],{"type":24,"value":90},"参加者は、自分の馴染みのあるさいたま市の街並みが3Dで再現された画面を実際に操作し、建物の高さや属性データを確認するなど、データの具体的な手触りを楽しみました。",{"type":18,"tag":27,"props":92,"children":93},{},[94],{"type":18,"tag":31,"props":95,"children":98},{"alt":96,"src":97},"ハンズオンの様子","/images/report/260211/touch-hands-on.jpg",[],{"type":18,"tag":51,"props":100,"children":102},{"id":101},"考えるアイデアソン地域課題へのアプローチ",[103],{"type":24,"value":104},"【考える】アイデアソン：地域課題へのアプローチ",{"type":18,"tag":27,"props":106,"children":107},{},[108],{"type":24,"value":109},"後半のメインプログラムであるアイデアソン（70分）では、グループに分かれて「このデータを使って、さいたま市で何ができるか」を検討しました。「浸水リスクの可視化による新しい防災訓練の形」や「道路冠水のリアルタイム可視化システム」など、シビックテックらしい、市民の視点に立ったユニークで実用的なアイデアが提案されました。",{"type":18,"tag":27,"props":111,"children":112},{},[113],{"type":18,"tag":31,"props":114,"children":117},{"alt":115,"src":116},"アイデアソンの様子","/images/report/260211/think-ideathon.jpg",[],{"type":18,"tag":119,"props":120,"children":121},"ul",{},[122,134],{"type":18,"tag":123,"props":124,"children":125},"li",{},[126,132],{"type":18,"tag":127,"props":128,"children":129},"strong",{},[130],{"type":24,"value":131},"主催:",{"type":24,"value":133}," シビックテックさいたま",{"type":18,"tag":123,"props":135,"children":136},{},[137,142],{"type":18,"tag":127,"props":138,"children":139},{},[140],{"type":24,"value":141},"協力:",{"type":24,"value":143}," 国土交通省、株式会社武蔵野銀行",{"title":7,"searchDepth":145,"depth":145,"links":146},2,[147,148,149],{"id":53,"depth":145,"text":56},{"id":77,"depth":145,"text":80},{"id":101,"depth":145,"text":104},"markdown","content:data:260211-plateau-ideathon.md","content","data/260211-plateau-ideathon.md","data/260211-plateau-ideathon","md",1771335000663]